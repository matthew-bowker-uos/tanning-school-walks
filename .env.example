# Copy to .env (or to a Drive-stored file mounted in Colab) and fill in values.
# Never commit the populated .env. Never echo these in notebook output.
# This file IS committed to the public repo — only keep placeholders here.

# Google Cloud Places API key, restricted to Places API + IP/referrer.
GOOGLE_PLACES_API_KEY=YOUR_KEY_HERE

# GitHub repo coordinates (used by Stage 3 to assert the hypothesis-lock tag exists).
GITHUB_OWNER=matthew-bowker-uos
GITHUB_REPO=tanning-school-walks

# Optional override for data root. If unset, src.schools_sunbeds.config picks
# the Colab path (/content/drive/MyDrive/schools-sunbeds-data) or the local
# repo's ./data depending on environment.
DATA_ROOT=
